<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER"
      prefHeight="700.0"
      prefWidth="1000.0"
      spacing="20.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cashflow.controller.DashboardController">

    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0"/>
    </padding>

    <children>

        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label text="💰 CASHFLOW DASHBOARD"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0984E3;">
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel"
                   text="Halo, User!"
                   style="-fx-font-size: 13px; -fx-text-fill: #636E72;"/>
            <Button text="Logout"
                    prefHeight="34.0"
                    prefWidth="90.0"
                    onAction="#handleLogout"
                    style="-fx-background-color: #D63031;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;
                           -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="20.0" alignment="CENTER">
            <children>

                <VBox alignment="CENTER" prefHeight="110.0" prefWidth="220.0"
                      style="-fx-background-color: #55EFC4; -fx-background-radius: 12;">
                    <Label text="Total Income"
                           style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                    <Label fx:id="incomeLabel" text="Rp 0"
                           style="-fx-font-weight: bold; -fx-font-size: 20px;"/>
                </VBox>

                <VBox alignment="CENTER" prefHeight="110.0" prefWidth="220.0"
                      style="-fx-background-color: #FF7675; -fx-background-radius: 12;">
                    <Label text="Total Expense"
                           style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                    <Label fx:id="expenseLabel" text="Rp 0"
                           style="-fx-font-weight: bold; -fx-font-size: 20px;"/>
                </VBox>

                <VBox alignment="CENTER" prefHeight="110.0" prefWidth="220.0"
                      style="-fx-background-color: #74B9FF; -fx-background-radius: 12;">
                    <Label text="Current Balance"
                           style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
                    <Label fx:id="balanceLabel" text="Rp 0"
                           style="-fx-font-weight: bold; -fx-font-size: 20px;"/>
                </VBox>

            </children>
        </HBox>

        <HBox alignment="CENTER" spacing="15.0">
            <Button text="+ Tambah Income"
                    prefWidth="180.0" prefHeight="40.0"
                    onAction="#handleOpenIncome"/>
            <Button text="- Tambah Expense"
                    prefWidth="180.0" prefHeight="40.0"
                    onAction="#handleOpenExpense"
                    style="-fx-background-color: #D63031; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
            <Button text="📋 Lihat Transaksi"
                    prefWidth="180.0" prefHeight="40.0"
                    onAction="#handleOpenTransaction"
                    style="-fx-background-color: #6C5CE7; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 10; -fx-cursor: hand;"/>
        </HBox>

        <VBox spacing="10.0">
            <Label text="Recent Transactions"
                   style="-fx-font-weight: bold; -fx-font-size: 18px;"/>

            <TableView fx:id="transactionTable"
                       prefHeight="380.0"
                       prefWidth="960.0">
                <columns>
                    <TableColumn fx:id="idColumn"          text="ID"          prefWidth="60.0"/>
                    <TableColumn fx:id="typeColumn"        text="Type"        prefWidth="110.0"/>
                    <TableColumn fx:id="amountColumn"      text="Amount"      prefWidth="160.0"/>
                    <TableColumn fx:id="dateColumn"        text="Date"        prefWidth="130.0"/>
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="240.0"/>
                    <TableColumn fx:id="detailColumn"      text="Detail"      prefWidth="200.0"/>
                </columns>
            </TableView>
        </VBox>

    </children>

</VBox>
