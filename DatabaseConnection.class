<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER"
      prefHeight="520.0"
      prefWidth="420.0"
      spacing="0.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="cashflow.controller.LoginController"
      style="-fx-background-color: #F5F6FA;">

    <VBox alignment="CENTER"
          spacing="16.0"
          style="-fx-background-color: white;
                 -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.12), 16, 0, 0, 4);">

        <padding>
            <Insets top="40.0" right="40.0" bottom="40.0" left="40.0"/>
        </padding>

        <Label text="💰 CashFlow"
               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #0984E3;">
        </Label>

        <Label text="Masuk ke akun Anda"
               style="-fx-font-size: 14px; -fx-text-fill: #636E72;">
        </Label>

        <Separator prefWidth="340.0"/>

        <VBox spacing="6.0">
            <Label text="Username atau Email"
                   style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
            <TextField fx:id="usernameField"
                       promptText="Masukkan username atau email"
                       prefWidth="340.0"/>
        </VBox>

        <VBox spacing="6.0">
            <Label text="Password"
                   style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Masukkan password"
                           prefWidth="340.0"/>
        </VBox>

        <Label fx:id="errorLabel"
               text=""
               style="-fx-text-fill: #D63031; -fx-font-size: 12px;"
               wrapText="true"
               prefWidth="340.0"/>

        <Button text="Masuk"
                prefWidth="340.0"
                prefHeight="42.0"
                onAction="#handleLogin"
                style="-fx-background-color: #0984E3;
                       -fx-text-fill: white;
                       -fx-font-size: 14px;
                       -fx-font-weight: bold;
                       -fx-background-radius: 10;
                       -fx-cursor: hand;"/>

        <Separator prefWidth="340.0"/>

        <HBox alignment="CENTER" spacing="4.0">
            <Label text="Belum punya akun?"
                   style="-fx-font-size: 13px; -fx-text-fill: #636E72;"/>
            <Hyperlink text="Daftar sekarang"
                       onAction="#handleGoToSignUp"
                       style="-fx-font-size: 13px; -fx-text-fill: #0984E3; -fx-font-weight: bold;"/>
        </HBox>

    </VBox>

</VBox>
